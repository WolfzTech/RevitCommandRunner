        <File Source="$(var.BundleDir)\Contents\2022\RevitCommandRunner.pdb" />
        <File Source="$(var.BundleDir)\Contents\2022\Newtonsoft.Json.dll" />
        <File Source="$(var.ManifestPath)" Name="RevitCommandRunner.addin" />
      </Component>

      <Component Id="Revit2023Component" Directory="Revit2023Folder" Guid="C06D1C60-764A-43C8-91F3-957B8C75FE93">
        <File Source="$(var.BundleDir)\Contents\2023\RevitCommandRunner.dll" KeyPath="yes" />
        <File Source="$(var.BundleDir)\Contents\2023\RevitCommandRunner.pdb" />
        <File Source="$(var.BundleDir)\Contents\2023\Newtonsoft.Json.dll" />
        <File Source="$(var.ManifestPath)" Name="RevitCommandRunner.addin" />
      </Component>

      <Component Id="Revit2024Component" Directory="Revit2024Folder" Guid="20E72913-D144-4112-82BD-A6F8E8505CC9">
        <File Source="$(var.BundleDir)\Contents\2024\RevitCommandRunner.dll" KeyPath="yes" />
        <File Source="$(var.BundleDir)\Contents\2024\RevitCommandRunner.pdb" />
        <File Source="$(var.BundleDir)\Contents\2024\Newtonsoft.Json.dll" />
        <File Source="$(var.ManifestPath)" Name="RevitCommandRunner.addin" />
      </Component>

      <Component Id="Revit2025Component" Directory="Revit2025Folder" Guid="14C3D7E9-E77E-442C-85A8-7E73D37D0895">
        <File Source="$(var.BundleDir)\Contents\2025\RevitCommandRunner.dll" KeyPath="yes" />
        <File Source="$(var.BundleDir)\Contents\2025\RevitCommandRunner.pdb" />
        <File Source="$(var.ManifestPath)" Name="RevitCommandRunner.addin" />
      </Component>

      <Component Id="Revit2026Component" Directory="Revit2026Folder" Guid="4D34D0A3-6790-4E92-A124-2D7C0215F3F3">
        <File Source="$(var.BundleDir)\Contents\2026\RevitCommandRunner.dll" KeyPath="yes" />
        <File Source="$(var.BundleDir)\Contents\2026\RevitCommandRunner.pdb" />
        <File Source="$(var.ManifestPath)" Name="RevitCommandRunner.addin" />
      </Component>

      <Component Id="Revit2027Component" Directory="Revit2027Folder" Guid="FE3E9AE4-D9C9-4D8D-9B19-B950C390DBE5">
        <File Source="$(var.BundleDir)\Contents\2027\RevitCommandRunner.dll" KeyPath="yes" />
        <File Source="$(var.BundleDir)\Contents\2027\RevitCommandRunner.pdb" />
        <File Source="$(var.ManifestPath)" Name="RevitCommandRunner.addin" />
      </Component>
    </ComponentGroup>
  </Package>
</Wix>
