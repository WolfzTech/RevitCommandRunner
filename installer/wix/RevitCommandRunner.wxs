<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="RevitCommandRunner"
    Manufacturer="DIAL"
    Version="1.0.0.0"
    UpgradeCode="7C46B670-3802-4B96-83B5-5970C5C7A0B9"
    Scope="perUser">

    <MajorUpgrade DowngradeErrorMessage="A newer version of RevitCommandRunner is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="RevitCommandRunner" Level="1">
      <ComponentGroupRef Id="RevitCommandRunnerComponents" />
    </Feature>

    <StandardDirectory Id="AppDataFolder">
      <Directory Id="AutodeskFolder" Name="Autodesk">
        <Directory Id="RevitFolder" Name="Revit">
          <Directory Id="AddinsFolder" Name="Addins">
            <Directory Id="Revit2021Folder" Name="2021" />
            <Directory Id="Revit2022Folder" Name="2022" />
            <Directory Id="Revit2023Folder" Name="2023" />
            <Directory Id="Revit2024Folder" Name="2024" />
            <Directory Id="Revit2025Folder" Name="2025" />
            <Directory Id="Revit2026Folder" Name="2026" />
            <Directory Id="Revit2027Folder" Name="2027" />
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="RevitCommandRunnerComponents">
      <Component Id="Revit2021Component" Directory="Revit2021Folder" Guid="1F6F4F50-D406-46D1-AF49-40234A886421">
        <File Source="$(var.BundleDir)\Contents\2021\RevitCommandRunner.dll" KeyPath="yes" />
        <File Source="$(var.BundleDir)\Contents\2021\RevitCommandRunner.pdb" />
        <File Source="$(var.BundleDir)\Contents\2021\Newtonsoft.Json.dll" />
        <File Source="$(var.ManifestPath)" Name="RevitCommandRunner.addin" />
      </Component>

      <Component Id="Revit2022Component" Directory="Revit2022Folder" Guid="BC9B7C2C-8574-4F8E-8351-216BB4112D33">
